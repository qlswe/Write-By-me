rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (from Firebase Auth)
    // Fields:
    //   - favorites: list of strings (optional) - List of favorite item IDs
    //   - lang: string (optional) - Preferred language
    //   - lowPerfMode: boolean (optional) - Low performance mode flag
    //   - role: string (required) - User role: 'admin', 'moderator', 'user'
    //   - createdAt: string (optional) - ISO timestamp of creation
    //
    // Collection: comments
    // Document ID: auto-generated
    // Fields:
    //   - targetId: string (required) - ID of the theory or post
    //   - parentId: string (optional) - ID of the parent comment, if this is a reply
    //   - authorUid: string (required) - UID of the author
    //   - authorName: string (required) - Display name of the author
    //   - authorPhoto: string (optional) - Photo URL of the author
    //   - content: string (required) - The comment text
    //   - likesCount: number (optional) - Number of likes
    //   - likedBy: list of strings (optional) - List of UIDs who liked the comment
    //   - createdAt: string (required) - ISO timestamp of creation
    //
    // Collection: feedback
    // Document ID: auto-generated
    // Fields:
    //   - type: string (required) - Type of feedback
    //   - text: string (required) - Feedback content
    //   - image: string (optional) - Base64 encoded image
    //   - logs: string (optional) - Application logs
    //   - uid: string (optional) - User ID if logged in
    //   - createdAt: string (required) - ISO timestamp of creation
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
       return request.auth != null;
    }
    
    function isOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "semegladysev527@gmail.com" && request.auth.token.email_verified == true));
    }

    function isModerator() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'moderator' || isAdmin());
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'displayName', 'email', 'photoURL', 'favorites', 'lang', 'lowPerfMode', 'role', 'createdAt', 'lastLogin']) &&
             (!('uid' in data) || data.uid is string) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('email' in data) || (data.email is string && data.email.size() <= 200)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             (!('favorites' in data) || (data.favorites is list && data.favorites.size() <= 1000)) &&
             (!('lang' in data) || (data.lang is string && data.lang.size() <= 10)) &&
             (!('lowPerfMode' in data) || data.lowPerfMode is bool) &&
             (!('role' in data) || (data.role is string && data.role in ['admin', 'moderator', 'user'])) &&
             (!('createdAt' in data) || data.createdAt is string) &&
             (!('lastLogin' in data) || data.lastLogin is string);
    }

    function isValidChat(data) {
      return hasRequiredFields(['participants']) &&
             hasOnlyAllowedFields(['participants', 'createdAt', 'lastMessage', 'lastMessageAt']) &&
             data.participants is list && data.participants.size() == 2 &&
             request.auth.uid in data.participants &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('lastMessage' in data) || (data.lastMessage is string && data.lastMessage.size() <= 1000)) &&
             (!('lastMessageAt' in data) || data.lastMessageAt is timestamp);
    }

    function isValidMessage(data) {
      return hasRequiredFields(['senderId', 'text', 'createdAt']) &&
             hasOnlyAllowedFields(['senderId', 'text', 'createdAt']) &&
             data.senderId == request.auth.uid &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 2000 &&
             data.createdAt is timestamp;
    }

    function isValidComment(data) {
      return hasRequiredFields(['targetId', 'authorUid', 'authorName', 'content', 'createdAt']) &&
             hasOnlyAllowedFields(['targetId', 'parentId', 'authorUid', 'authorName', 'authorPhoto', 'content', 'likesCount', 'likedBy', 'reactions', 'isEdited', 'createdAt']) &&
             data.targetId is string && data.targetId.size() > 0 && data.targetId.size() <= 100 &&
             (!('parentId' in data) || data.parentId == null || (data.parentId is string && data.parentId.size() <= 100)) &&
             data.authorUid is string && data.authorUid == request.auth.uid &&
             data.authorName is string && data.authorName.size() > 0 && data.authorName.size() <= 100 &&
             (!('authorPhoto' in data) || (data.authorPhoto is string && data.authorPhoto.size() <= 1000)) &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 2000 &&
             (!('likesCount' in data) || (data.likesCount is number && data.likesCount >= 0)) &&
             (!('likedBy' in data) || (data.likedBy is list && data.likedBy.size() <= 10000)) &&
             (!('reactions' in data) || (data.reactions is map)) &&
             (!('isEdited' in data) || (data.isEdited is bool)) &&
             data.createdAt is string;
    }

    function isValidLikeUpdate() {
      let diff = request.resource.data.diff(resource.data);
      let affectedKeys = diff.affectedKeys();
      let oldLikesCount = resource.data.get('likesCount', 0);
      let newLikesCount = request.resource.data.get('likesCount', 0);
      let oldLikedBy = resource.data.get('likedBy', []);
      let newLikedBy = request.resource.data.get('likedBy', []);
      
      return isAuthenticated() &&
             affectedKeys.hasOnly(['likesCount', 'likedBy']) &&
             (
               // Like
               (newLikesCount == oldLikesCount + 1 &&
                !(request.auth.uid in oldLikedBy) &&
                (request.auth.uid in newLikedBy)) ||
               // Unlike
               (newLikesCount == oldLikesCount - 1 &&
                (request.auth.uid in oldLikedBy) &&
                !(request.auth.uid in newLikedBy))
             );
    }

    function isValidFeedback(data) {
      return hasRequiredFields(['type', 'text', 'createdAt']) &&
             hasOnlyAllowedFields(['type', 'text', 'image', 'logs', 'uid', 'createdAt']) &&
             data.type is string && data.type.size() > 0 && data.type.size() <= 50 &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 5000 &&
             (!('image' in data) || (data.image is string && data.image.size() <= 5242880)) && // 5MB limit
             (!('logs' in data) || (data.logs is string && data.logs.size() <= 1048576)) && // 1MB limit
             (!('uid' in data) || (data.uid is string && (data.uid == request.auth.uid || data.uid == 'anonymous'))) &&
             data.createdAt is string;
    }

    function isValidLocalizedString(field, maxLen) {
      return (field is string && field.size() > 0 && field.size() <= maxLen) ||
             (field is map && field.size() > 0 && field.size() <= 10 &&
              (!('en' in field) || (field.en is string && field.en.size() <= maxLen)) &&
              (!('ru' in field) || (field.ru is string && field.ru.size() <= maxLen)) &&
              (!('by' in field) || (field.by is string && field.by.size() <= maxLen)) &&
              (!('jp' in field) || (field.jp is string && field.jp.size() <= maxLen)) &&
              (!('de' in field) || (field.de is string && field.de.size() <= maxLen)) &&
              (!('fr' in field) || (field.fr is string && field.fr.size() <= maxLen)) &&
              (!('zh' in field) || (field.zh is string && field.zh.size() <= maxLen)));
    }

    function isValidTheory(data) {
      return hasRequiredFields(['category', 'title', 'summary', 'content', 'createdAt', 'authorUid']) &&
             hasOnlyAllowedFields(['category', 'title', 'summary', 'content', 'createdAt', 'updatedAt', 'authorUid']) &&
             data.category is string && data.category in ['lore', 'characters', 'gameplay'] &&
             isValidLocalizedString(data.title, 200) &&
             isValidLocalizedString(data.summary, 1000) &&
             isValidLocalizedString(data.content, 50000) &&
             data.createdAt is string &&
             (!('updatedAt' in data) || data.updatedAt is string) &&
             data.authorUid is string && data.authorUid == request.auth.uid;
    }

    function isValidBlogPost(data) {
      return hasRequiredFields(['category', 'title', 'summary', 'content', 'createdAt', 'authorUid']) &&
             hasOnlyAllowedFields(['category', 'title', 'summary', 'content', 'createdAt', 'updatedAt', 'authorUid']) &&
             data.category is string && data.category in ['updates', 'personal'] &&
             isValidLocalizedString(data.title, 200) &&
             isValidLocalizedString(data.summary, 1000) &&
             isValidLocalizedString(data.content, 50000) &&
             data.createdAt is string &&
             (!('updatedAt' in data) || data.updatedAt is string) &&
             data.authorUid is string && data.authorUid == request.auth.uid;
    }

    function isValidEvent(data) {
      return hasRequiredFields(['icon', 'title', 'description', 'type', 'createdAt', 'authorUid']) &&
             hasOnlyAllowedFields(['icon', 'title', 'description', 'type', 'dayOfWeek', 'weekOffset', 'startDate', 'endDate', 'resetTime', 'createdAt', 'updatedAt', 'authorUid']) &&
             data.icon is string && data.icon.size() > 0 && data.icon.size() <= 50 &&
             isValidLocalizedString(data.title, 200) &&
             isValidLocalizedString(data.description, 1000) &&
             data.type is string && data.type in ['daily', 'weekly', 'one-time'] &&
             (!('dayOfWeek' in data) || (data.dayOfWeek is number && data.dayOfWeek >= 0 && data.dayOfWeek <= 6)) &&
             (!('weekOffset' in data) || (data.weekOffset is number && data.weekOffset >= 0 && data.weekOffset <= 1)) &&
             (!('resetTime' in data) || (data.resetTime is string && data.resetTime.matches("^\\d{2}:\\d{2}$"))) &&
             (!('startDate' in data) || data.startDate is string) &&
             (!('endDate' in data) || data.endDate is string) &&
             data.createdAt is string &&
             (!('updatedAt' in data) || data.updatedAt is string) &&
             data.authorUid is string && data.authorUid == request.auth.uid;
    }

    function isValidPublicProfile(data) {
      return hasOnlyAllowedFields(['uid', 'displayName', 'photoURL', 'role']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100 &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             (!('role' in data) || (data.role is string && data.role in ['admin', 'moderator', 'user']));
    }

    function isValidUserPost(data) {
      return hasRequiredFields(['uid', 'text', 'createdAt']) &&
             hasOnlyAllowedFields(['uid', 'authorName', 'authorPhoto', 'text', 'createdAt', 'updatedAt']) &&
             data.uid is string && data.uid == request.auth.uid &&
             (!('authorName' in data) || (data.authorName is string && data.authorName.size() <= 100)) &&
             (!('authorPhoto' in data) || (data.authorPhoto is string && data.authorPhoto.size() <= 1000)) &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 5000 &&
             data.createdAt is string &&
             (!('updatedAt' in data) || data.updatedAt is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'user' || isAdmin());
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && 
                        request.resource.data.role == resource.data.role &&
                        (!('createdAt' in request.resource.data) || 
                         !('createdAt' in resource.data) || 
                         request.resource.data.createdAt == resource.data.createdAt)) ||
                       (isAdmin() && isValidUser(request.resource.data));
      allow delete: if isAdmin();
    }

    match /public_profiles/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) && isValidPublicProfile(request.resource.data);
    }

    match /user_posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidUserPost(request.resource.data);
      allow update: if isOwner(resource.data.uid) && isValidUserPost(request.resource.data) &&
                    request.resource.data.uid == resource.data.uid &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && isValidChat(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants && isValidChat(request.resource.data);
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants && isValidMessage(request.resource.data);
      }
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidComment(request.resource.data);
      allow update: if (isOwner(resource.data.authorUid) && isValidComment(request.resource.data) &&
                        request.resource.data.authorUid == resource.data.authorUid &&
                        request.resource.data.targetId == resource.data.targetId &&
                        request.resource.data.createdAt == resource.data.createdAt) ||
                       isValidLikeUpdate() ||
                       (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']));
      allow delete: if isOwner(resource.data.authorUid) || isModerator();
    }

    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isValidFeedback(request.resource.data);
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /theories/{theoryId} {
      allow read: if true;
      allow create: if isAdmin() && isValidTheory(request.resource.data);
      allow update: if isAdmin() && isValidTheory(request.resource.data) &&
                    request.resource.data.createdAt == resource.data.createdAt &&
                    request.resource.data.authorUid == resource.data.authorUid;
      allow delete: if isAdmin();
    }

    match /blogPosts/{postId} {
      allow read: if true;
      allow create: if isAdmin() && isValidBlogPost(request.resource.data);
      allow update: if isAdmin() && isValidBlogPost(request.resource.data) &&
                    request.resource.data.createdAt == resource.data.createdAt &&
                    request.resource.data.authorUid == resource.data.authorUid;
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isAdmin() && isValidEvent(request.resource.data);
      allow update: if isAdmin() && isValidEvent(request.resource.data) &&
                    request.resource.data.createdAt == resource.data.createdAt &&
                    request.resource.data.authorUid == resource.data.authorUid;
      allow delete: if isAdmin();
    }

    match /promo_codes/{promoId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
