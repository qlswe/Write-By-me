{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "User profile data including preferences and roles.",
      "type": "object",
      "properties": {
        "favorites": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of favorite theory or post IDs."
        },
        "lang": {
          "type": "string",
          "description": "Preferred language code."
        },
        "lowPerfMode": {
          "type": "boolean",
          "description": "Whether low performance mode is enabled."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "moderator", "user"],
          "description": "The user's access role."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the profile was created."
        }
      }
    },
    "sdk_reports": {
      "title": "SDK Reports",
      "description": "User feedback and bug reports sent via the SDK.",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["bug", "feedback", "system"],
          "description": "The type of report."
        },
        "data": {
          "type": "object",
          "description": "The report data (e.g., message)."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the report was sent."
        },
        "version": {
          "type": "string",
          "description": "The SDK version."
        },
        "userAgent": {
          "type": "string",
          "description": "The user's browser agent."
        },
        "url": {
          "type": "string",
          "description": "The URL where the report was sent from."
        }
      },
      "required": ["type", "data", "timestamp"]
    },
    "public_profiles": {
      "title": "Public Profile",
      "description": "Publicly visible user information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["uid", "displayName"]
    },
    "user_posts": {
      "title": "User Post",
      "description": "User-created post or note (Юзы).",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "Private user profile documents."
    },
    "/public_profiles/{userId}": {
      "schema": "public_profiles",
      "description": "Public user profile documents."
    },
    "/user_posts/{postId}": {
      "schema": "user_posts",
      "description": "Collection of user-created posts (Юзы)."
    },
    "/sdk_reports/{reportId}": {
