{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User preferences and progress",
      "type": "object",
      "properties": {
        "favorites": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of favorite item IDs"
        },
        "lang": {
          "type": "string",
          "description": "Preferred language"
        },
        "createdAt": {
          "type": "string",
          "description": "ISO timestamp of creation"
        }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "User profile data"
    }
  }
}
