{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User preferences and progress",
      "type": "object",
      "properties": {
        "favorites": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of favorite item IDs"
        },
        "lang": {
          "type": "string",
          "description": "Preferred language"
        },
        "lowPerfMode": {
          "type": "boolean",
          "description": "Low performance mode flag"
        },
        "createdAt": {
          "type": "string",
          "description": "ISO timestamp of creation"
        }
      }
    },
    "Comment": {
      "title": "Comment",
      "description": "A user comment on a theory or post",
      "type": "object",
      "properties": {
        "targetId": {
          "type": "string",
          "description": "ID of the theory or post"
        },
        "parentId": {
          "type": "string",
          "description": "ID of the parent comment, if this is a reply"
        },
        "authorUid": {
          "type": "string",
          "description": "UID of the author"
        },
        "authorName": {
          "type": "string",
          "description": "Display name of the author"
        },
        "authorPhoto": {
          "type": "string",
          "description": "Photo URL of the author"
        },
        "content": {
          "type": "string",
          "description": "The comment text"
        },
        "likesCount": {
          "type": "number",
          "description": "Number of likes"
        },
        "likedBy": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of UIDs who liked the comment"
        },
        "reactions": {
          "type": "object",
          "description": "Map of emoji to list of UIDs"
        },
        "isEdited": {
          "type": "boolean",
          "description": "Whether the comment has been edited"
        },
        "createdAt": {
          "type": "string",
          "description": "ISO timestamp of creation"
        }
      },
      "required": ["targetId", "authorUid", "authorName", "content", "createdAt"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback submission",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "description": "Type of feedback (bug, suggestion)"
        },
        "text": {
          "type": "string",
          "description": "Feedback content"
        },
        "image": {
          "type": "string",
          "description": "Base64 encoded image or URL"
        },
        "logs": {
          "type": "string",
          "description": "Application logs"
        },
        "uid": {
          "type": "string",
          "description": "User ID if logged in"
        },
        "createdAt": {
          "type": "string",
          "description": "ISO timestamp of creation"
        }
      },
      "required": ["type", "text", "createdAt"]
    },
    "BlogPost": {
      "title": "BlogPost",
      "description": "A blog post",
      "type": "object",
      "properties": {
        "title": {
          "type": "object",
          "description": "Localized title"
        },
        "summary": {
          "type": "object",
          "description": "Localized summary"
        },
        "content": {
          "type": "object",
          "description": "Localized content"
        },
        "category": {
          "type": "string",
          "description": "Category of the post"
        },
        "updatedAt": {
          "type": "string",
          "description": "ISO timestamp of last update"
        }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "User profile data"
    },
    "/comments/{commentId}": {
      "schema": {
        "$ref": "#/entities/Comment"
      },
      "description": "Comments on theories and posts"
    },
    "/feedback/{feedbackId}": {
      "schema": {
        "$ref": "#/entities/Feedback"
      },
      "description": "User feedback submissions"
    },
    "/blogPosts/{postId}": {
      "schema": {
        "$ref": "#/entities/BlogPost"
      },
      "description": "Blog posts"
    }
  }
}
